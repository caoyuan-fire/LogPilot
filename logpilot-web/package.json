{
  "name": "logpilot-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1",
    "dev:server": "tsx watch src/server/index.ts",
    "dev": "run-p dev:web dev:server",
    "build": "tsc -b && vite build",
